# Optional: WebSocket URL for authoritative PvP when not using ?matchWs= in the URL.
# Vite dev with ?match=pvp defaults to ws://<page-hostname>:8788 if this is unset.
# Production / preview builds should set this or pass matchWs on every PvP link.
# VITE_MATCH_WS=ws://127.0.0.1:8788

# Match dev server port (Node only, see server/matchDevServer.ts)
# MATCH_DEV_PORT=8788
